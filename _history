   # Pin t…ônziml…ôm…ôl…ôri kitin modelin…ô gΟΕr…ô d…ôyi≈ü…ô bil…ôr\n    # pin1.write_digital(1) ...\n    return 20 # Sm cinsind…ôn m…ôsaf…ô qaytarΡ±r\n\ndef stop():\n    drive(0, 0)\n\ndef turn_right():\n    drive(40, -40)\n    utime.sleep_ms(400) # 90 d…ôr…ôc…ô dΟΕnm…ô mΟΦdd…ôti (testl…ô t…ônziml…ônm…ôlidir)\n    stop()\n\ndef turn_left():\n    drive(-40, 40)\n    utime.sleep_ms(400)\n    stop()\n\n# Τèsas dΟΕvr (Loop)\nwhile True:\n    # 2.2. B…ôndin…ô …ôsas…ôn robot tam avtonom ba≈ülamalΡ±dΡ±r\n    if button_a.is_pressed():\n        display.show(Image.TARGET)\n        utime.sleep_ms(1000) # Start dΟΦym…ôsin…ô basdΡ±qdan sonra 1 saniy…ô gΟΕzl…ô\n        \n        while True:\n            dist = get_distance()\n            \n            # 1. Ο•nd…ô mane…ô yoxdursa ir…ôli get\n            if dist > 15:\n                drive(30, 30)\n            \n            # 2. Mane…ô varsa, saΡü …ôl qaydasΡ±nΡ± t…ôtbiq et\n            else:\n                stop()\n                # Burada yan sensorlar (IR) varsa onlardan m…ôlumat alΡ±nΡ±r\n                # Τèg…ôr yan sensor yoxdursa, robot saΡüa dΟΕnm…ôy…ô c…ôhd edir\n                turn_right()\n                \n                # SaΡüa dΟΕndΟΦkd…ôn sonra yol h…ôl…ô d…ô baΡülΡ±dΡ±rsa, sola (…ôslind…ô …ôvv…ôlki dΟΦzΟΦn…ô) dΟΕn\n                if get_distance() < 15:\n                    turn_left()\n                    turn_left() # Sola dΟΕnm…ôk ΟΦΟßΟΦn iki d…ôf…ô saΡüΡ±n …ôksini edir\n            \n            utime.sleep_ms(50)"}]},{"timestamp":1774944698231,"editorVersion":"8.0.18","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":73,"length1":47,"diffs":[[1,"        \"core\": \"*\"\n"]]}]},{"type":"edited","filename":"main.py","patch":[{"start1":0,"length1":93,"diffs":[[1,"from microbit import *\nimport utime\n"]]},{"start1":37,"length1":120,"diffs":[[1,"# Qeyd: Bu kod mΟΦh…ôrrikl…ôri I2C ΟΦz…ôrind…ôn idar…ô ed…ôn standart\n# Micro:bit robot ≈üassil…ôri (m…ôs: Cutebot/Tinybit) ΟΦΟßΟΦn strukturla≈üdΡ