≈ü…ônl…ôr\nsΟΦr…ôt = 35\ndΟΕnm…ô_mΟΦdd…ôti = 450  # 90 d…ôr…ôc…ô ΟΦΟßΟΦn bu r…ôq…ômi test edib d…ôyi≈ü…ô bil…ôrs…ôn\nyarΡ±≈ü_ba≈üladΡ± = False\n\ndef mΟΦh…ôrrik_idar…ô(sol, saΡü):\n    # Bu hiss…ô robotun modelin…ô gΟΕr…ô d…ôyi≈üir.\n    # Τèg…ôr Tinybit istifad…ô edirs…ôns…ô:\n    # tinybit.car_ctrl_speed(tinybit.CarState.CAR_RUN, sol, saΡü)\n    # Τèg…ôr standart Micro:bit pinl…ôridirs…ô (P1 v…ô P2):\n    pins.analog_write_pin(AnalogPin.P1, sol * 10)\n    pins.analog_write_pin(AnalogPin.P2, saΡü * 10)\n\ndef dayan():\n    pins.analog_write_pin(AnalogPin.P1, 0)\n    pins.analog_write_pin(AnalogPin.P2, 0)\n\ndef saΡüa_dΟΕn():\n    pins.analog_write_pin(AnalogPin.P1, 400)\n    pins.analog_write_pin(AnalogPin.P2, 0)\n    basic.pause(dΟΕnm…ô_mΟΦdd…ôti)\n    dayan()\n\ndef sola_dΟΕn():\n    pins.analog_write_pin(AnalogPin.P1, 0)\n    pins.analog_write_pin(AnalogPin.P2, 400)\n    basic.pause(dΟΕnm…ô_mΟΦdd…ôti)\n    dayan()\n\ndef m…ôsaf…ô_ΟΕlΟß():\n    # P0 v…ô P1 pinl…ôrind…ôn istifad…ô ed…ôn ultrasonik sensor ΟΦΟßΟΦn:\n    return sonar.ping(DigitalPin.P0, DigitalPin.P1, PingUnit.CENTIMETERS)\n\n# A dΟΦym…ôsin…ô basanda yarΡ±≈ü ba≈ülayΡ±r (Qayda 3.2-y…ô uyΡüun)\ndef on_button_pressed_a():\n    global yarΡ±≈ü_ba≈üladΡ±\n    basic.show_icon(IconNames.TARGET)\n    basic.pause(1000)\n    yarΡ±≈ü_ba≈üladΡ± = True\ninput.on_button_pressed(Button.A, on_button_pressed_a)\n\ndef on_forever():\n    global yarΡ±≈ü_ba≈üladΡ±\n    if yarΡ±≈ü_ba≈üladΡ±:\n        d = m…ôsaf…ô_ΟΕlΟß()\n        \n        # 1. Yol aΟßΡ±qdΡ±rsa (15 sm-d…ôn Οßoxdursa) dΟΦz get\n        if d > 15 or d == 0: # 0 b…ôz…ôn sensorun x…ôtasΡ± ola bil…ôr, yolun bo≈ü olduΡüunu gΟΕst…ôrir\n            mΟΦh…ôrrik_idar…ô(sΟΦr…ôt, sΟΦr…ôt)\n        \n        # 2. Mane…ô gΟΕrdΟΦkd…ô saΡü …ôl qaydasΡ±nΡ± t…ôtbiq et\n        else:\n            dayan()\n            basic.pause(200)\n            \n            # Ο•nc…ô saΡüa dΟΕnm…ôy…ô ΟßalΡ±≈ü\n            saΡüa_dΟΕn()\n            basic.pause(200)\n            \n            # SaΡüa dΟΕndΟΦkd…ôn sonra yol h…ôl…ô d…ô baΡülΡ±dΡ±rsa, sola (…ôslind…ô sola 180 d…ôr…ôc…ô) dΟΕn\n            if m…ôsaf…ô_ΟΕlΟß() < 15:\n                sola_dΟΕn()\n                sola_dΟΕn()\n            \n    basic.pause(20)\n\nbasic.forever(on_forever)","pxt.json":"{\n    \"name\": \"maze eldar\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-sonar\": \"github:microsoft/pxt-sonar#v0.0.6\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}}],"shares":[],"lastSaveTime":1774945792070}